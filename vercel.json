{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/sleep",
      "dest": "/api/sleep.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
